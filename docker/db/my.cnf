[mysqld]
# Baseline tuning for Moodle workload in single-node Docker.
skip-name-resolve=1
max_connections=400
thread_cache_size=64
table_open_cache=4096
table_definition_cache=4096
open_files_limit=65535

# InnoDB defaults tuned for moderate concurrency.
innodb_buffer_pool_size=1G
innodb_buffer_pool_instances=1
innodb_log_file_size=256M
innodb_log_buffer_size=64M
innodb_flush_log_at_trx_commit=1
innodb_flush_method=O_DIRECT
innodb_file_per_table=1
innodb_read_io_threads=4
innodb_write_io_threads=4

# Reduce temporary table spills for report-heavy workloads.
tmp_table_size=64M
max_heap_table_size=64M

# Keep slow query visibility for real tuning.
slow_query_log=1
long_query_time=1
