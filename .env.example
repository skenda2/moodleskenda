# Timezone container PHP.
TZ=Asia/Jakarta

# PHP-FPM sizing default aman untuk host kecil (sekitar 2 vCPU / 8 GB RAM).
PHP_FPM_PM=dynamic
PHP_FPM_MAX_CHILDREN=24
PHP_FPM_START_SERVERS=4
PHP_FPM_MIN_SPARE_SERVERS=4
PHP_FPM_MAX_SPARE_SERVERS=12
PHP_FPM_MAX_REQUESTS=700
PHP_FPM_REQUEST_TERMINATE_TIMEOUT=300s
PHP_FPM_REQUEST_SLOWLOG_TIMEOUT=10s

# Port host untuk akses Nginx (container web expose port 80).
MOODLE_PORT=8080

# Gunakan IP/domain yang bisa diakses klien lain (hindari localhost bila akses lintas perangkat).
MOODLE_URL=http://IP_LXC:8080

# Jika di belakang reverse proxy/HTTPS (contoh Cloudflare, Nginx host, port-forwarding HTTPS).
MOODLE_REVERSEPROXY=false
MOODLE_SSLPROXY=false

# Bahasa dan identitas situs Moodle.
MOODLE_LANG=id
MOODLE_FULLNAME="Moodle Skenda"
MOODLE_SHORTNAME="Skenda LMS"

# Akun admin awal Moodle.
MOODLE_ADMIN_USER=admin
MOODLE_ADMIN_PASS=GantiPasswordKuat123!
MOODLE_ADMIN_EMAIL=admin@example.com

# Kredensial database MariaDB.
DB_ROOT_PASSWORD=ganti_root_password_kuat
DB_NAME=moodle
DB_USER=moodle
DB_PASSWORD=ganti_db_password_kuat

# Redis (cache + session).
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PREFIX=moodle_
